#!/bin/bash
set -e

echo "🚦 vibe-control 预推送检查..."

if [ -f "vibe-control/scripts/pr-check.sh" ]; then
    CHECK="vibe-control/scripts/pr-check.sh"
elif [ -f "scripts/pr-check.sh" ]; then
    CHECK="scripts/pr-check.sh"
else
    echo "⚠️  未找到 pr-check.sh，跳过预推送检查"
    exit 0
fi

echo ""
if bash "$CHECK"; then
    echo ""
    echo "✅ 预推送检查通过"
    exit 0
else
    echo ""
    echo "❌ 预推送检查失败，推送被阻止"
    echo ""
    echo "恢复建议："
    echo "  1. 查看 failed 的具体检测项"
    echo "  2. 运行 bash $CHECK 定位问题"
    echo "  3. 修复后重新 git push"
    exit 1
fi
