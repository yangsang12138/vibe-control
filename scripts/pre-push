#!/bin/bash
set -e

echo "🚦 vibe-control 预推送检查..."

echo ""
if bash vibe-control/scripts/pr-check.sh; then
    echo ""
    echo "✅ 预推送检查通过"
    exit 0
else
    echo ""
    echo "❌ 预推送检查失败，推送被阻止"
    echo ""
    echo "恢复建议："
    echo "  1. 查看 failed 的具体检测项"
    echo "  2. 运行 bash vibe-control/scripts/pr-check.sh 定位问题"
    echo "  3. 修复后重新 git push"
    exit 1
fi
